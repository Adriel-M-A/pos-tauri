# === NexPOS .gitignore ===

# Node / Frontend / Scripts
node_modules/
dist/
dist-ssr/
*.local
.npm
.eslintcache

# Rust / Tauri
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/
target/

# Base de Datos (SQLite Local)
*.db
*.db-journal
*.db-shm
*.db-wal

# Logs y Debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Entorno y Secretos
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editores e IDEs
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.buildlog

# Sistema Operativo
.DS_Store
Thumbs.db
Desktop.ini

# Otros
temp/
out/
build/
node_modules
